{
  "name": "concord",
  "private": true,
  "scripts": {
    "build": "dotenv -- turbo run build",
    "dev": "dotenv -- turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"apps/**/*.{ts,tsx,md}\" \"packages/**/*.{ts,tsx,md}\" \"*.md\" --ignore-path .prettierignore",
    "check-types": "turbo run check-types",
    "deploy-commands": "dotenv -- turbo run deploy-commands"
  },
  "devDependencies": {
    "dotenv": "catalog:",
    "dotenv-cli": "catalog:",
    "prettier": "3.7.4",
    "turbo": "2.9.6",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=18"
  }
}
