{
  "plansDirectory": ".plans",
  "permissions": {
    "allow": [
      "mcp__notion__notion-fetch",
      "Bash(git show:*)",
      "Bash(docker exec:*)",
      "Bash(docker ps:*)",
      "Bash(docker inspect:*)",
      "Bash(docker logs:*)",
      "Bash(wc:*)",
      "Bash(cat:*)",
      "Bash(find:*)",
      "Bash(ls:*)",
      "Bash(xargs:*)",
      "Bash(gh issue view:*)",
      "Bash(gh issue comment:*)",
      "Bash(gh pr create:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr edit:*)",
      "Bash(pnpm check-types:*)",
      "Bash(pnpm lint:*)",
      "Bash(pnpm format:*)",
      "Read(.env.local)"
    ],
    "deny": ["Read(.env)", "Read(.env.production)"],
    "ask": ["Bash(gh issue close:*)", "Bash(curl:*)", "Bash(ssh:*)"]
  }
}
